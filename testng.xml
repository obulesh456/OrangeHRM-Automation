<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="OrangeHRM Test Suite" verbose="1" parallel="false" thread-count="1">

    <parameter name="browser" value="edge"/>
    <parameter name="url" value="https://opensource-demo.orangehrmlive.com/web/index.php/auth/login"/>

    <listeners>
        <listener class-name="listeners.TestListener"/>
    </listeners>

    <!-- Add more test suites here -->

    <test name="Dashboard Tests">
        <classes>
            <class name="tests.DashboardTests"/>
        </classes>
    </test>

    <test name="Login Tests">
        <classes>
            <class name="tests.LoginTests"/>
        </classes>
    </test>

    <test name="Admin Tests">
        <classes>
            <class name="tests.AdminTests"/>
        </classes>
    </test>

    <test name="Recruitment Tests">
        <classes>
            <class name="tests.RecruitmentTests"/>
        </classes>
    </test>


</suite>
